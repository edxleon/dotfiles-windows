{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} @ {{ .Folder }}",
  "palette": {
    "bg":         "#1a1b26",
    "bg_dark":    "#16161e",
    "blue":       "#7aa2f7",
    "cyan":       "#7dcfff",
    "green":      "#9ece6a",
    "magenta":    "#bb9af7",
    "orange":     "#ff9e64",
    "red":        "#f7768e",
    "teal":       "#73daca",
    "white":      "#c0caf5",
    "yellow":     "#e0af68",
    "dim":        "#565f89",
    "git_ahead":  "#9ece6a",
    "git_behind": "#f7768e"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "p:bg_dark",
          "background": "p:blue",
          "template": "  "
        },
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:bg_dark",
          "background": "p:teal",
          "template": "  {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:white",
          "background": "p:bg",
          "properties": {
            "style": "folder",
            "folder_icon": "",
            "home_icon": "",
            "max_depth": 3
          },
          "template": "  {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:bg_dark",
          "background": "p:magenta",
          "foreground_templates": [
            "{{ if .Detached }}p:orange{{ end }}",
            "{{ if .Merge }}p:red{{ end }}"
          ],
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:yellow{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:orange{{ end }}",
            "{{ if gt .Ahead 0 }}p:git_ahead{{ end }}",
            "{{ if gt .Behind 0 }}p:git_behind{{ end }}"
          ],
          "properties": {
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ if .UpstreamIcon }}{{ .UpstreamIcon }} {{ end }} {{ .HEAD }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if gt .Ahead 0 }}  {{ .Ahead }}{{ end }}{{ if gt .Behind 0 }}  {{ .Behind }}{{ end }} "
        },
        {
          "type": "exit",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "p:bg_dark",
          "background": "p:green",
          "background_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "template": " {{ if gt .Code 0 }} {{ .Code }}{{ else }}{{ end }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "node",
          "style": "plain",
          "foreground": "p:green",
          "template": " {{ .Full }} ",
          "properties": {
            "display_mode": "files"
          }
        },
        {
          "type": "python",
          "style": "plain",
          "foreground": "p:yellow",
          "template": " {{ .Full }} ",
          "properties": {
            "display_mode": "files"
          }
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "p:dim",
          "template": " {{ .CurrentDate | date \"15:04\" }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:blue",
          "template": " "
        }
      ]
    }
  ]
}
